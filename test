private void logEntry(@RequestBody LogEntryDto logEntry) {
    Map<String, Object> genericLogFields = new HashMap<>();
    genericLogFields.put("uid", logEntry.getUid());
    genericLogFields.put("type", logEntry.getType());
    genericLogFields.put("message", logEntry.getMessage());
    genericLogFields.put("versionCode", logEntry.getVersionCode());
    genericLogFields.put("platform", logEntry.getPlatform());
    genericLogFields.put("submitted", logEntry.getSubmitted());

    // Log the general information as structured log
    specialLogger.info("Bug report received", StructuredArguments.fields(genericLogFields));

    // Process and log each detailed log entry with uid included
    logEntry.getLogs().forEach(detail -> logDetail(detail, logEntry.getUid()));
}

private void logDetail(LogDetailDto detail, String uid) {
    Map<String, Object> logFields = new HashMap<>();
    logFields.put("uid", uid); // Include the Correlation ID in every log entry
    logFields.put("date", detail.getDate());
    logFields.put("level", detail.getLevel());
    logFields.put("log", detail.getLog());

    // Adjust the logging level as before, now with structured logging
    specialLogger.info("Detailed log entry", StructuredArguments.fields(logFields));
}
