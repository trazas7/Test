
<configuration>
    <!-- Keep your existing Logback configurations here -->

    <!-- Define a variable for the base log directory -->
    <property name="LOGS_BASE_DIR" value="C:/data/logs/gmportal/share-ui"/>

    <!-- Define a new appender for logging to a file based on date and service name -->
    <appender name="SPECIAL-LOGGER" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOGS_BASE_DIR}/service-name.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} - %msg%n</pattern>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- daily rollover with directory based on date -->
            <fileNamePattern>${LOGS_BASE_DIR}/%d{dd-MM-yyyy}/service-name.log</fileNamePattern>
            <!-- keep 30 days' worth of history -->
            <maxHistory>30</maxHistory>
        </rollingPolicy>
    </appender>

    <!-- Define a logger that uses the new appender -->
    <logger name="specialLogger" level="DEBUG" additivity="false">
        <appender-ref ref="SPECIAL-LOGGER"/>
    </logger>

</configuration>
