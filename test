import org.slf4j.MDC;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RestController;
import java.util.UUID;

@RestController
public class LogEntryController {

    private static final Logger logger = LoggerFactory.getLogger(LogEntryController.class);

    @PostMapping("/api/log")
    public void logEntry(@RequestBody LogEntryDto logEntry) {
        // Generate a unique correlation ID and set it in MDC
        String correlationId = UUID.randomUUID().toString();
        MDC.put("correlationId", correlationId);

        try {
            // Log the generic message along with detailed log entries
            logger.info("Received log entry for UID: {}", logEntry.getUid());
            logEntry.getLogs().forEach(this::logDetail);

            // Process other necessary actions...
        } finally {
            // Clear MDC to avoid leaking data
            MDC.clear();
        }
    }

    private void logDetail(LogDetailDto detail) {
        // Assuming you have already set the correlationId in MDC
        // Log the detailed message with the correlation ID automatically included
        logger.info("[{}] Date: {}, Level: {}, Log: {}", MDC.get("correlationId"), detail.getDate(), detail.getLevel(), detail.getLog());
    }
}


<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} [%thread] [CorrelationID: %X{correlationId}] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>
    <root level="info">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
